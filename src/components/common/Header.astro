---
import { getLangFromUrl, getLocalizedPath, languages, t } from '../../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const siteBase = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-white/80 dark:bg-slate-900/80 border-b border-slate-200 dark:border-slate-700">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href={lang === 'en' ? siteBase : `${siteBase}hi/`} class="flex items-center gap-2 text-ripple-blue hover:opacity-80 transition-opacity">
      <span class="text-2xl">🌊</span>
      <span class="font-[var(--font-display)] font-bold text-xl hidden sm:inline">{t(lang, 'site.title')}</span>
    </a>

    <nav class="flex items-center gap-3">
      <a href={lang === 'en' ? siteBase : `${siteBase}hi/`} class="text-sm font-semibold text-slate-600 dark:text-slate-300 hover:text-ripple-blue transition-colors">
        {t(lang, 'nav.home')}
      </a>
      <a href={lang === 'en' ? `${siteBase}chapters/01-the-first-ripple` : `${siteBase}hi/chapters/01-the-first-ripple`} class="text-sm font-semibold text-slate-600 dark:text-slate-300 hover:text-ripple-blue transition-colors hidden sm:inline">
        {t(lang, 'nav.startReading')}
      </a>

      <!-- Language switcher -->
      <div class="relative" id="lang-switcher">
        <button
          id="lang-toggle"
          class="flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-ripple-blue/10 dark:bg-ripple-blue/20 text-ripple-blue dark:text-blue-400 text-sm font-semibold hover:bg-ripple-blue/20 dark:hover:bg-ripple-blue/30 transition-colors"
        >
          <span class="text-base">{lang === 'hi' ? '🇮🇳' : '🌐'}</span>
          <span>{languages[lang]}</span>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div id="lang-dropdown" class="hidden absolute right-0 top-full mt-1 bg-white dark:bg-slate-800 rounded-xl shadow-xl border border-slate-200 dark:border-slate-700 overflow-hidden min-w-[140px] z-50">
          {Object.entries(languages).map(([code, name]) => {
            const targetPath = getLocalizedPath(currentPath, code as 'en' | 'hi');
            return (
              <a href={targetPath}
                 class:list={[
                   'flex items-center gap-2 px-4 py-2.5 text-sm font-medium transition-colors',
                   code === lang
                     ? 'bg-ripple-blue/10 text-ripple-blue dark:text-blue-400'
                     : 'text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700'
                 ]}>
                <span>{code === 'hi' ? '🇮🇳' : '🌐'}</span>
                <span>{name}</span>
                {code === lang && <span class="ml-auto text-ripple-blue">✓</span>}
              </a>
            );
          })}
        </div>
      </div>

      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="p-2 rounded-full bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors"
      >
        <span class="dark:hidden">🌙</span>
        <span class="hidden dark:inline">☀️</span>
      </button>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // Language dropdown
  const langToggle = document.getElementById('lang-toggle');
  const langDropdown = document.getElementById('lang-dropdown');
  langToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    langDropdown?.classList.toggle('hidden');
  });
  document.addEventListener('click', () => {
    langDropdown?.classList.add('hidden');
  });
</script>
