---
interface Props {
  items: string[];
}
const { items } = Astro.props;
---

<div class="my-8 p-6 bg-gradient-to-br from-green-50 to-teal-50 dark:from-green-900/20 dark:to-teal-900/20 rounded-2xl border-2 border-ripple-green">
  <h3 class="font-[var(--font-display)] text-xl font-bold text-ripple-green dark:text-green-400 mb-4 flex items-center gap-2">
    <span>📝</span> Chapter Summary
  </h3>
  <ul class="space-y-2">
    {items.map((item: string) => (
      <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
        <span class="text-ripple-green mt-0.5">✓</span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
</div>
