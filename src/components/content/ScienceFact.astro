---
interface Props {
  source?: string;
  year?: string;
  note?: string;
}
const { source, year, note } = Astro.props;
---

<div class="my-6 p-5 bg-blue-50 dark:bg-blue-900/20 border-l-4 border-ripple-blue rounded-r-xl">
  <div class="flex items-start gap-3">
    <span class="text-2xl flex-shrink-0">🔬</span>
    <div>
      <div class="font-bold text-ripple-blue dark:text-blue-400 text-sm uppercase tracking-wide mb-1">Science Fact</div>
      <div class="text-slate-700 dark:text-slate-300">
        <slot />
      </div>
      {(source || note) && (
        <div class="mt-2 text-xs text-slate-500 dark:text-slate-400 italic">
          {source && <span>Source: {source}{year && ` (${year})`}</span>}
          {note && <div class="mt-1">Note: {note}</div>}
        </div>
      )}
    </div>
  </div>
</div>
