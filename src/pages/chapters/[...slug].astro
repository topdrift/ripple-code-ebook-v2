---
import { getCollection, render } from 'astro:content';
import ChapterLayout from '../../layouts/ChapterLayout.astro';

export async function getStaticPaths() {
  const chapters = await getCollection('chapters');
  const sorted = chapters.sort((a, b) => a.data.chapter - b.data.chapter);

  return sorted.map((entry, index) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prevSlug: index > 0 ? sorted[index - 1].id : undefined,
      nextSlug: index < sorted.length - 1 ? sorted[index + 1].id : undefined,
      prevTitle: index > 0 ? `Ch ${sorted[index - 1].data.chapter}` : undefined,
      nextTitle: index < sorted.length - 1 ? `Ch ${sorted[index + 1].data.chapter}` : undefined,
    },
  }));
}

const { entry, prevSlug, nextSlug, prevTitle, nextTitle } = Astro.props;
const { Content } = await render(entry);
---

<ChapterLayout
  title={entry.data.title}
  subtitle={entry.data.subtitle}
  chapter={entry.data.chapter}
  part={entry.data.part}
  partTitle={entry.data.partTitle}
  features={entry.data.features}
  icon={entry.data.icon}
  prevSlug={prevSlug}
  nextSlug={nextSlug}
  prevTitle={prevTitle}
  nextTitle={nextTitle}
>
  <Content />
</ChapterLayout>
