---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { PARTS } from '../lib/chapters';

const chapters = await getCollection('chapters');
const sorted = chapters.sort((a, b) => a.data.chapter - b.data.chapter);
const siteBase = import.meta.env.BASE_URL;

// Group chapters by part
const grouped = PARTS.map(part => ({
  ...part,
  chapters: sorted.filter(c => c.data.part === part.num),
})).filter(g => g.chapters.length > 0);
---

<BaseLayout title="Home" description="An interactive educational journey teaching children emotional intelligence, social skills, and cause-and-effect thinking through the ripple metaphor.">

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 pt-16 pb-12 text-center">
      <!-- Decorative ripple circles -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] opacity-5 pointer-events-none">
        <div class="absolute inset-0 rounded-full border-2 border-ripple-blue animate-[pulse-glow_4s_ease-in-out_infinite]"></div>
        <div class="absolute inset-8 rounded-full border-2 border-ripple-blue animate-[pulse-glow_4s_ease-in-out_0.5s_infinite]"></div>
        <div class="absolute inset-16 rounded-full border-2 border-ripple-blue animate-[pulse-glow_4s_ease-in-out_1s_infinite]"></div>
      </div>

      <div class="relative z-10">
        <span class="text-6xl mb-6 block animate-[float_3s_ease-in-out_infinite]">🌊</span>
        <h1 class="font-[var(--font-display)] text-4xl md:text-6xl font-bold text-ripple-blue dark:text-blue-400 mb-4">
          The Ripple Code
        </h1>
        <p class="text-xl md:text-2xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto mb-8">
          An Interactive Journey for Young Ripple Makers
        </p>
        <p class="text-lg text-slate-500 dark:text-slate-500 max-w-xl mx-auto mb-10">
          Every action creates ripples that spread outward, just like dropping a stone in water.
          Learn to create positive ripples that make the world better!
        </p>

        <div class="flex flex-wrap justify-center gap-4">
          {sorted.length > 0 && (
            <a href={`${siteBase}chapters/${sorted[0].id}`}
               class="px-8 py-3.5 bg-gradient-to-r from-ripple-blue to-blue-600 text-white font-bold text-lg rounded-full shadow-lg hover:-translate-y-1 hover:shadow-xl transition-all">
              Start Chapter 1
            </a>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {[
        { icon: '🎮', title: '50+ Activities', desc: 'Games, puzzles, and interactive exercises' },
        { icon: '🔬', title: 'Science-Backed', desc: 'Based on verified psychology research' },
        { icon: '📊', title: 'Track Progress', desc: 'Watch your ripple skills grow' },
        { icon: '🏆', title: 'Earn Badges', desc: 'Unlock achievements as you learn' },
      ].map(f => (
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-5 text-center shadow-md hover:-translate-y-1 transition-transform">
          <div class="text-3xl mb-2">{f.icon}</div>
          <h3 class="font-[var(--font-display)] font-bold text-sm mb-1 text-slate-800 dark:text-slate-200">{f.title}</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Chapters by Part -->
  <section class="max-w-6xl mx-auto px-4 py-8">
    <h2 class="font-[var(--font-display)] text-3xl font-bold text-center text-slate-800 dark:text-slate-200 mb-10">
      Your Learning Journey
    </h2>

    <div class="space-y-10">
      {grouped.map(group => (
        <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg overflow-hidden">
          <div class="px-6 py-4 bg-gradient-to-r from-ripple-blue/10 to-ripple-teal/10 dark:from-ripple-blue/20 dark:to-ripple-teal/20 border-b border-slate-200 dark:border-slate-700">
            <h3 class="font-[var(--font-display)] text-xl font-bold text-ripple-blue dark:text-blue-400">
              <span class="mr-2">{group.icon}</span>
              Part {group.num}: {group.title}
            </h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">{group.description}</p>
          </div>
          <div class="divide-y divide-slate-100 dark:divide-slate-700">
            {group.chapters.map(ch => (
              <a href={`${siteBase}chapters/${ch.id}`}
                 class="flex items-center gap-4 px-6 py-4 hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors group">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-ripple-blue to-blue-600 text-white flex items-center justify-center font-bold text-sm flex-shrink-0">
                  {ch.data.chapter}
                </div>
                <div class="flex-1 min-w-0">
                  <h4 class="font-semibold text-slate-800 dark:text-slate-200 group-hover:text-ripple-blue dark:group-hover:text-blue-400 transition-colors truncate">
                    {ch.data.title}
                  </h4>
                  <p class="text-sm text-slate-500 dark:text-slate-400 truncate">{ch.data.subtitle}</p>
                </div>
                <span class="text-xl flex-shrink-0">{ch.data.icon}</span>
                <svg class="w-5 h-5 text-slate-400 group-hover:text-ripple-blue dark:group-hover:text-blue-400 transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Learning outcomes -->
  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="font-[var(--font-display)] text-3xl font-bold text-center text-slate-800 dark:text-slate-200 mb-10">
      What You'll Learn
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {[
        { icon: '🧠', title: 'Emotional Intelligence', items: ['Recognize and manage emotions', 'Stay calm in tough situations', 'Use positive tone and body language'] },
        { icon: '🤝', title: 'Social Skills', items: ['Build trust and friendships', 'Communicate clearly and kindly', 'Resolve conflicts peacefully'] },
        { icon: '🎯', title: 'Life Skills', items: ['Track patterns and learn from experience', 'Set goals and build good habits', 'Take responsibility for actions'] },
        { icon: '🔬', title: 'Scientific Thinking', items: ['Understand cause and effect', 'Test ideas and learn from results', 'Observe patterns and predict outcomes'] },
      ].map(cat => (
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-md">
          <div class="text-3xl mb-3">{cat.icon}</div>
          <h3 class="font-[var(--font-display)] font-bold text-lg mb-3 text-ripple-blue dark:text-blue-400">{cat.title}</h3>
          <ul class="space-y-2">
            {cat.items.map(item => (
              <li class="flex items-start gap-2 text-sm text-slate-600 dark:text-slate-400">
                <span class="text-ripple-green mt-0.5 flex-shrink-0">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="bg-gradient-to-r from-ripple-blue to-blue-600 rounded-3xl p-8 md:p-12 text-center text-white shadow-xl">
      <h2 class="font-[var(--font-display)] text-3xl font-bold mb-4">Ready to Begin?</h2>
      <p class="text-lg text-blue-100 mb-6 max-w-lg mx-auto">
        Start with Chapter 1 and discover the amazing power of ripples!
      </p>
      {sorted.length > 0 && (
        <a href={`${siteBase}chapters/${sorted[0].id}`}
           class="inline-block px-8 py-3.5 bg-white text-ripple-blue font-bold text-lg rounded-full shadow-lg hover:-translate-y-1 hover:shadow-xl transition-all">
          Start Chapter 1: The First Ripple 🌊
        </a>
      )}
    </div>
  </section>

</BaseLayout>
