---
import BaseLayout from './BaseLayout.astro';
import { t } from '../i18n/translations';
import type { Lang } from '../i18n/translations';

interface Props {
  title: string;
  subtitle: string;
  chapter: number;
  part: number;
  partTitle: string;
  features: string[];
  icon: string;
  prevSlug?: string;
  nextSlug?: string;
  prevTitle?: string;
  nextTitle?: string;
  lang?: Lang;
}

const { title, subtitle, chapter, part, partTitle, features, icon, prevSlug, nextSlug, prevTitle, nextTitle, lang = 'en' } = Astro.props;
const siteBase = import.meta.env.BASE_URL;
const chapterBase = lang === 'hi' ? `${siteBase}hi/chapters/` : `${siteBase}chapters/`;
const homeBase = lang === 'hi' ? `${siteBase}hi/` : siteBase;
---

<BaseLayout title={`${t(lang, 'chapter.chapter')} ${chapter}: ${title}`} description={subtitle} lang={lang} chapter={chapter} chapterTitle={title}>
  <!-- Reading progress bar -->
  <div id="reading-progress" class="fixed top-[57px] left-0 w-full h-1 z-40 bg-slate-200 dark:bg-slate-700">
    <div id="reading-progress-bar" class="h-full bg-gradient-to-r from-ripple-blue to-ripple-teal transition-all duration-150 w-0"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- Chapter header -->
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-ripple-blue/10 dark:bg-ripple-blue/20 rounded-full text-sm font-semibold text-ripple-blue mb-4">
        {t(lang, 'chapter.part')} {part}: {partTitle}
      </div>
      <div class="text-5xl mb-4">{icon}</div>
      <h1 class="font-[var(--font-display)] text-3xl md:text-4xl font-bold text-ripple-blue dark:text-blue-400 mb-3">
        {t(lang, 'chapter.chapter')} {chapter}: {title}
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">{subtitle}</p>

      {features.length > 0 && (
        <div class="flex flex-wrap justify-center gap-2 mt-4">
          {features.map((f: string) => (
            <span class="px-3 py-1 bg-ripple-purple/10 dark:bg-ripple-purple/20 text-ripple-purple dark:text-purple-400 text-sm font-semibold rounded-full">
              {f}
            </span>
          ))}
        </div>
      )}
    </div>

    <!-- Chapter content -->
    <article class="prose max-w-none bg-white dark:bg-slate-800 rounded-2xl shadow-lg p-6 md:p-10">
      <slot />
    </article>

    <!-- Chapter navigation -->
    <nav class="flex items-center justify-between mt-10 gap-4">
      {prevSlug ? (
        <a href={`${chapterBase}${prevSlug}`}
           class="flex items-center gap-2 px-5 py-3 bg-ripple-green text-white font-bold rounded-full hover:-translate-y-0.5 transition-all shadow-md">
          <span>←</span>
          <span class="hidden sm:inline">{prevTitle}</span>
          <span class="sm:hidden">{t(lang, 'chapter.prev')}</span>
        </a>
      ) : <div />}

      <a href={homeBase}
         class="px-5 py-3 bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-300 font-bold rounded-full hover:-translate-y-0.5 transition-all">
        {t(lang, 'chapter.allChapters')}
      </a>

      {nextSlug ? (
        <a href={`${chapterBase}${nextSlug}`}
           class="flex items-center gap-2 px-5 py-3 bg-ripple-orange text-white font-bold rounded-full hover:-translate-y-0.5 transition-all shadow-md">
          <span class="hidden sm:inline">{nextTitle}</span>
          <span class="sm:hidden">{t(lang, 'chapter.next')}</span>
          <span>→</span>
        </a>
      ) : <div />}
    </nav>
  </div>

  <script>
    const bar = document.getElementById('reading-progress-bar');
    if (bar) {
      window.addEventListener('scroll', () => {
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const pct = docHeight > 0 ? (window.scrollY / docHeight) * 100 : 0;
        bar.style.width = `${Math.min(pct, 100)}%`;
      });
    }
  </script>
</BaseLayout>
